  "item": [
    {
      "name": "API 1: Get All Products List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let jsonData = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "",
              "pm.test(\"Response time is less than 3s\", function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});",
              "",
              "",
              "pm.test(\"Response code is 200\", function () {",
              "    pm.expect(jsonData.responseCode).to.eql(200);",
              "});",
              "",
              "//verify products list exist ",
              "pm.test(\"Products list exists\", function () {",
              "    pm.expect(jsonData).to.have.property(\"products\");",
              "    pm.expect(jsonData.products).to.be.an(\"array\");",
              "});",
              "",
              "",
              "//validate products list is not empty ",
              "pm.test(\"Products list is not empty\", function () {",
              "    pm.expect(jsonData.products.length).to.be.above(0);",
              "});",
              "",
              "",
              "",
              "//validate the products list structure",
              "pm.test(\"Each product has valid structure\", function () {",
              "",
              "    jsonData.products.forEach((product) => {",
              "        pm.expect(product).to.have.property(\"id\");",
              "        pm.expect(product).to.have.property(\"name\");",
              "        pm.expect(product).to.have.property(\"price\");",
              "        pm.expect(product).to.have.property(\"brand\");",
              "        pm.expect(product).to.have.property(\"category\");",
              "",
              "        // Nested validation",
              "        pm.expect(product.category).to.have.property(\"usertype\");",
              "        pm.expect(product.category).to.have.property(\"category\");",
              "",
              "        pm.expect(product.category.usertype).to.have.property(\"usertype\");",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
